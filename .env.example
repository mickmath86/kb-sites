# --- Supabase ---
# Project: kb-smb-outreach (rtlhldhumcmzgbvkqmnm)
NEXT_PUBLIC_SUPABASE_URL=https://rtlhldhumcmzgbvkqmnm.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only, never expose to client. Used in:
#  - generateStaticParams (build time)
#  - /api/revalidate route
#  - scripts/generate-copy.ts
SUPABASE_SERVICE_ROLE_KEY=

# --- PostHog (client-side analytics on preview sites) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- DeepSeek via OpenRouter (used only by scripts/generate-copy.ts) ---
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: override the model. Defaults to deepseek/deepseek-chat-v3-0324.
# DEEPSEEK_MODEL=deepseek/deepseek-chat-v3-0324

# --- On-demand revalidation ---
# Any random string. POST to /api/revalidate with header `x-revalidate-secret: <this>`.
# Current live value in Vercel:
#   078d52004b2d6d475eb108008ea4c6021d711e2931b21df9556c488a665308f4
REVALIDATE_SECRET=

# Where scripts/generate-copy.ts POSTs the revalidate call.
# Defaults to kb-sites-sooty.vercel.app (the diagnostic domain).
# REVALIDATE_HOST=kb-sites-sooty.vercel.app

# --- Preview hosting domain ---
# Root domain that wildcard subdomains hang off of, e.g. sites.kickbord.com
# Locally use sites.localhost
NEXT_PUBLIC_PREVIEW_ROOT_DOMAIN=sites.kickbord.com
